# Server
PORT=3000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/kfz-legal

# JWT
JWT_SECRET=your_super_secret_jwt_key_comes_here
JWT_EXPIRES_IN=7d

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# RAG - required for Sprint 1 CLI demo
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key

# RAG - optional model overrides
EMBED_MODEL=text-embedding-3-small
LLM_MODEL=claude-sonnet-4.5

# RAG - required vector database
RAG_MONGODB_URI=mongodb://localhost:27017/kfz-legal-rag